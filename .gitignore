# Based on GitHub's Python.gitignore template (pruned for relevance)
# https://github.com/github/gitignore/blob/main/Python.gitignore

# OS specific
.DS_Store

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.env
.venv
env/
venv/

# Jupyter Notebook
.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# mypy
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# ===================
# Project-specific
# ===================

# Pipeline outputs (generated by the workflow)
/data/
output/

/gene_ontology/

# notes
docs/

# Archived code (untracked local copies)
archive/src_2/
archive/notebooks/

# Planning docs
planning/
*_PLAN.md

# Connectivity search backend data
connectivity-search-backend/data/postgres/
.DS_Store

# hpc
slurm*
/hpc/logs/
